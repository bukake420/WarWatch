# Copy this to .env.local for local development
# In Netlify: Site Settings → Environment Variables → Add variable

# Required — AI-generated OSINT feed, SitRep, OSINT panels
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Telegram Bot for leaders tab (channel posts)
# Create a free bot: open Telegram → @BotFather → /newbot
# Then add your bot as admin to a Telegram channel you control.
# Forward IDF / Khamenei public channel posts into your channel
# to have them appear in the Leaders tab.
# TELEGRAM_BOT_TOKEN=123456789:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
